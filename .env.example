# Frontend + Edge API environment template

# Overlay API base (production)
VITE_OVERLAY_BASE_URL=https://backend-hermon.vercel.app/api/hermon

# Local Edge API emulation (uncomment when using `vc dev`)
# VITE_OVERLAY_BASE_URL=http://localhost:3000/api/hermon

# Admin credentials for Vercel Edge Functions
VERCEL_ADMIN_USER=
VERCEL_ADMIN_PASS=

# Edge Config identifiers (replace with actual values from Vercel CLI)
EDGE_CONFIG_ID=
EDGE_CONFIG_READ_TOKEN=
EDGE_CONFIG_WRITE_TOKEN=

# Optional: legacy HLS source
# VITE_STREAM_HLS_URL=http://localhost:8000/live/stream/index.m3u8
