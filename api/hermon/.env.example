# Edge API environment template
# Copy these into Vercel project settings or `.env.local` when using `vc dev`.

# Basic auth credentials for overlay admin routes
VERCEL_ADMIN_USER=
VERCEL_ADMIN_PASS=

# Vercel Edge Config connection string (preferred)
# Example: https://edge-config.vercel.com/<id>/config?token=<uuid>
EDGE_CONFIG=

# Optional legacy overrides (auto-derived from EDGE_CONFIG if present)
EDGE_CONFIG_ID=
EDGE_CONFIG_READ_TOKEN=
EDGE_CONFIG_WRITE_TOKEN=
