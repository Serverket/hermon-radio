# Edge API environment template
# Copy these into Vercel project settings or `.env.local` when using `vc dev`.

# Basic auth credentials for overlay admin routes
VERCEL_ADMIN_USER=
VERCEL_ADMIN_PASS=

# Vercel Edge Config identifiers (required for persistent overlay state)
# Obtain via:
#   vercel edge-config create hermon-overlay
#   vercel edge-config tokens create hermon-overlay --read
#   vercel edge-config tokens create hermon-overlay --write
EDGE_CONFIG_ID=
EDGE_CONFIG_READ_TOKEN=
EDGE_CONFIG_WRITE_TOKEN=
